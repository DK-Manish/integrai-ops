# =============================================================================
# IntegrAI Ops — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in your values before running the application.
# Never commit your .env file. It is excluded by .gitignore.
#
# This file is safe to commit — it contains no real credentials.
# =============================================================================


# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# General environment identifier: local | docker | production
APP_ENV=local

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# The base URL the backend is accessible at
BACKEND_URL=http://localhost:8000

# Allowed CORS origins — comma-separated list of frontend URLs
CORS_ORIGINS=http://localhost:5173


# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string
# Local example:  postgresql://integrai:integrai_password@localhost:5432/integrai_ops
# Neon example:   postgresql://user:password@ep-xxx.neon.tech/integrai_ops?sslmode=require
DATABASE_URL=postgresql://integrai:integrai_password@localhost:5433/integrai_ops

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

COOKIE_SECURE=false
COOKIE_SAMESITE=lax


# -----------------------------------------------------------------------------
# AI Providers — server-side only, never sent to the frontend
# -----------------------------------------------------------------------------

# Primary AI provider: gemini | ollama
AI_PROVIDER=gemini

# Gemini — obtain your API key from https://aistudio.google.com/
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-flash

# Ollama (optional local provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1


# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------

MCP_TRANSPORT=stdio
MCP_PORT=9000


# -----------------------------------------------------------------------------
# Seed data
# -----------------------------------------------------------------------------

SEED_ADMIN_EMAIL=admin@integrai-ops.local
SEED_ADMIN_PASSWORD=REPLACE_WITH_A_SECURE_ADMIN_PASSWORD


# -----------------------------------------------------------------------------
# Docker Compose (local development only)
# -----------------------------------------------------------------------------

POSTGRES_USER=integrai
POSTGRES_PASSWORD=integrai_password
POSTGRES_DB=integrai_ops
POSTGRES_PORT=5433