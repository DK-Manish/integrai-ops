# =============================================================================
# IntegrAI Ops — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.test.example

# Postman — only the .example version is committed
postman/environments/production.postman_environment.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.venv/
venv/
env/
.uv/
dist/
build/
*.egg-info/
*.egg
.eggs/
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*~

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.iml
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
*.log.*

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/